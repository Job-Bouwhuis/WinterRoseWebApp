@page "/uploads/list"
@rendermode RenderMode.InteractiveServer

@using WinterRose.Nexus.Registry.Features.Api.Apps.Services
@using WinterRose.Nexus.Registry.Features.Components
@using WinterRose.Nexus.Shared

@inject AppRepository AppRepository
@inject NavigationManager Navigation

<PageContainer>
    <PageHeader Title="Uploaded Versions" Subtitle="Manage releases and view available diffs" />

    @if (AppEntries is null)
    {
        <div class="text-muted">Loading...</div>
    }
    else if (!AppEntries.Any())
    {
        <Card>
            <p class="text-muted">No uploads found.</p>
        </Card>
    }
    else
    {
        @foreach (var group in AppEntries)
        {
            <Card>
                <div class="upload-group-header">
                    <span class="upload-group-name">@group.AppId</span>
                    <span class="upload-group-badge">@group.Versions.Count version@(group.Versions.Count != 1 ? "s" : "")</span>
                </div>

                <div class="upload-table-wrapper">
                    <table class="upload-table">
                        <thead class="upload-table-head">
                            <tr>
                                <th>Version</th>
                                <th>Uploaded</th>
                                <th>Diffs</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var version in group.Versions)
                            {
                                <tr>
                                    <td>
                                        <span class="upload-badge">@version.VersionLabel</span>
                                    </td>
                                    <td class="text-muted">
                                        @version.UploadedAt.ToString("yyyy-MM-dd HH:mm")
                                    </td>
                                    <td>
                                        @{
                                            var diffsFromThis = group.Diffs
                                                .Where(d => d.FromVersion == version.VersionLabel)
                                                .ToList();

                                            var higherVersions = group.Versions
                                                .Where(v => CompareVersions(v.VersionLabel, version.VersionLabel) > 0)
                                                .OrderBy(v => v.VersionLabel)
                                                .ToList();
                                        }

                                        @if (!higherVersions.Any())
                                        {
                                            <span class="text-muted fst-italic">latest</span>
                                        }
                                        else
                                        {
                                            <div class="diff-entries">
                                                @foreach (var diff in diffsFromThis)
                                                {
                                                    <div class="diff-entry">
                                                        <span class="diff-arrow">→</span>
                                                        <span class="upload-badge">@diff.ToVersion</span>

                                                        <div class="diff-actions">
                                                            <Button Variant="ButtonVariant.Ghost" 
                                                                   OnClick="() => DownloadDiff(diff)">
                                                                ↓
                                                            </Button>
                                                        </div>
                                                    </div>
                                                }

                                                @if (!diffsFromThis.Any())
                                                {
                                                    <span class="text-muted fst-italic">no diffs</span>
                                                }
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </Card>
        }
    }
</PageContainer>

@code {
    private List<AppEntry>? AppEntries;

    protected override async Task OnInitializedAsync()
    {
        AppEntries = await AppRepository.GetAppEntries();
    }

    private void DownloadDiff(DiffEntry diff)
    {
    }


    private static int CompareVersions(string a, string b)
    {
        static int[] Parse(string v) =>
            v.Split('_').Select(p => int.TryParse(p, out var n) ? n : 0).ToArray();

        var pa = Parse(a);
        var pb = Parse(b);
        var len = Math.Max(pa.Length, pb.Length);

        for (int i = 0; i < len; i++)
        {
            var ai = i < pa.Length ? pa[i] : 0;
            var bi = i < pb.Length ? pb[i] : 0;
            if (ai != bi) return ai.CompareTo(bi);
        }

        return 0;
    }
}
