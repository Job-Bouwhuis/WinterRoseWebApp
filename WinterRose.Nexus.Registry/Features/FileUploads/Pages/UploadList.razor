@page "/uploads/list"
@rendermode InteractiveServer

@using WinterRose.Nexus.Registry.Features.Api.Apps.Services
@using WinterRose.Nexus.Shared
@using WinterRose.WinterForgeSerializing

@inject AppRepository AppRepository
@inject NavigationManager Navigation

<PageContainer>
    @if (AppEntries is null)
    {
        <div class="text-muted">Loading...</div>
    }
    else if (!AppEntries.Any())
    {
        <PageHeader Title="Uploaded Versions" Subtitle="Manage releases and view available diffs" />
        <Card>
            <p class="text-muted">No uploads found.</p>
        </Card>
    }
    else
    {
        @foreach (var app in AppEntries)
        {
            var latestStable = app.Versions
                .Where(v => string.IsNullOrEmpty(v.Tag))
                .OrderByDescending(v => v, VersionComparer)
                .FirstOrDefault();

            var latestByTag = app.Versions
                .Where(v => !string.IsNullOrEmpty(v.Tag))
                .GroupBy(v => v.Tag, StringComparer.OrdinalIgnoreCase)
                .Select(g => g.OrderByDescending(v => v, VersionComparer).First())
                .OrderBy(v => v.Tag, StringComparer.OrdinalIgnoreCase)
                .ToList();

            var orderedVersions = app.Versions
                .OrderByDescending(v => v, VersionComparer)
                .ToList();

            <Card>
                <div class="app-header">
                    <div class="app-header-titles">
                        <span class="app-name">@app.DisplayName</span>
                        <span class="app-publisher">by @app.Publisher</span>
                    </div>
                    <Button Variant="ButtonVariant.Primary" OnClick="() => UploadNewVersion(app.AppId)">
                        Upload New Version
                    </Button>
                </div>

                <div class="app-latest-summary">
                    @if (latestStable is not null)
                    {
                        <div class="app-latest-row">
                            <span class="app-latest-label">Latest Stable</span>
                            <span class="upload-badge">@latestStable.ToString(VersionStringFormat.HumanReadable)</span>
                        </div>
                    }
                    @foreach (var tagged in latestByTag)
                    {
                        <div class="app-latest-row">
                            <span class="app-latest-label">Latest @Capitalize(tagged.Tag)</span>
                            <span class="upload-badge">@tagged.ToString(VersionStringFormat.HumanReadable)</span>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(app.ShortDescription))
                {
                    <p class="app-description">@app.ShortDescription</p>
                }

                <div class="upload-table-wrapper">
                    <table class="upload-table">
                        <thead class="upload-table-head">
                            <tr>
                                <th></th>
                                <th>Version</th>
                                <th>Uploaded</th>
                                <th>Size</th>
                                <th>Diffs</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var version in orderedVersions)
                            {
                                var key = (app.AppId, version.VersionLabel);
                                var isExpanded = ExpandedRows.Contains(key);

                                var diffsFromThis = app.Diffs
                                    .Where(d => d.FromVersion == version.VersionLabel)
                                    .ToList();

                                <tr class="upload-row" @onclick="() => ToggleRow(key)">
                                    <td class="upload-expand-cell">
                                        <span class="upload-expand-caret @(isExpanded ? "expanded" : "")">▼</span>
                                    </td>
                                    <td>
                                        <span class="upload-badge">@version.ToString(VersionStringFormat.HumanReadable)</span>
                                    </td>
                                    <td class="text-muted">
                                        @FormatRelativeDate(version.UploadedAt)
                                    </td>
                                    <td class="text-muted">
                                        @FormatSize(version.InstallSize)
                                    </td>
                                    <td class="text-muted">
                                        @(diffsFromThis.Count > 0 ? diffsFromThis.Count.ToString() : "—")
                                    </td>
                                    <td class="upload-row-actions" @onclick:stopPropagation="true">
                                        <Button Variant="ButtonVariant.Ghost" OnClick="() => DownloadVersion(app, version)">
                                            Download
                                        </Button>
                                        <Button Variant="ButtonVariant.Danger" OnClick="() => ConfirmDeleteVersion(app, version)">
                                            Delete
                                        </Button>
                                    </td>
                                </tr>

                                @if (isExpanded)
                                {
                                    <tr class="upload-detail-row">
                                        <td colspan="6">
                                            <div class="upload-detail">
                                                <div class="upload-detail-grid">
                                                    <div class="upload-detail-field">
                                                        <span class="upload-detail-label">Uploaded</span>
                                                        <span>@version.UploadedAt.ToString("yyyy-MM-dd HH:mm")</span>
                                                    </div>
                                                    <div class="upload-detail-field">
                                                        <span class="upload-detail-label">Launch target</span>
                                                        <span>@version.LaunchTarget.Path</span>
                                                    </div>
                                                    <div class="upload-detail-field">
                                                        <span class="upload-detail-label">Install size</span>
                                                        <span>@FormatSize(version.InstallSize)</span>
                                                    </div>
                                                </div>

                                                @if (!string.IsNullOrWhiteSpace(version.Changelog))
                                                {
                                                    <div class="upload-detail-field">
                                                        <span class="upload-detail-label">Changelog</span>
                                                        <pre class="upload-changelog">@version.Changelog</pre>
                                                    </div>
                                                }

                                                <div class="upload-detail-field">
                                                    <span class="upload-detail-label">Diffs</span>
                                                    @if (!diffsFromThis.Any())
                                                    {
                                                        <span class="text-muted fst-italic">no diffs</span>
                                                    }
                                                    else
                                                    {
                                                        <div class="diff-entries">
                                                            @foreach (var diff in diffsFromThis)
                                                            {
                                                                <div class="diff-entry">
                                                                    <span class="diff-arrow">→</span>
                                                                    <span class="upload-badge">@diff.ToVersion</span>

                                                                    <div class="diff-actions">
                                                                        <Button Variant="ButtonVariant.Ghost"
                                                                               OnClick="() => DownloadDiff(diff)">
                                                                            Download
                                                                        </Button>
                                                                    </div>
                                                                </div>
                                                            }
                                                        </div>
                                                    }
                                                </div>

                                                <div class="upload-detail-actions">
                                                    <Button Variant="ButtonVariant.Ghost" OnClick="() => DownloadVersion(app, version)">
                                                        Download Version
                                                    </Button>
                                                    <Button Variant="ButtonVariant.Danger" OnClick="() => ConfirmDeleteVersion(app, version)">
                                                        Delete Version
                                                    </Button>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </Card>
        }
    }
</PageContainer>

<ConfirmDialog @ref="deleteConfirmDialog" />

@code {
    private List<AppEntry>? AppEntries;
    private readonly HashSet<(string AppId, string VersionLabel)> ExpandedRows = [];
    private static readonly IComparer<AppVersion> VersionComparer = Comparer<AppVersion>.Create((a, b) => a.CompareTo(b));
    private ConfirmDialog deleteConfirmDialog = null!;

    protected override async Task OnInitializedAsync()
    {
        AppEntries = await AppRepository.GetAppEntries();
    }

    private void ToggleRow((string AppId, string VersionLabel) key)
    {
        if (!ExpandedRows.Add(key))
            ExpandedRows.Remove(key);
    }

    private void DownloadDiff(DiffEntry diff)
    {
    }

    private void DownloadVersion(AppEntry app, AppVersion version)
    {
        Navigation.NavigateTo($"/api/apps/{app.AppId}/versions/{version.VersionLabel}/download", forceLoad: true);
    }

    private async Task ConfirmDeleteVersion(AppEntry app, AppVersion version)
    {
        var label = version.ToString(VersionStringFormat.HumanReadable);

        await deleteConfirmDialog.ShowAsync(
            title: $"Delete version {label}?",
            message: $"This will permanently remove {label} of {app.DisplayName} and its files from the server. This cannot be undone.",
            confirmText: "Delete",
            onConfirm: async () => await DeleteVersion(app, version));
    }

    private async Task DeleteVersion(AppEntry app, AppVersion version)
    {
        await AppRepository.DeleteVersion(app.AppId, version.VersionLabel);

        app.Versions.Remove(version);
        ExpandedRows.Remove((app.AppId, version.VersionLabel));

        StateHasChanged();
    }

    private void UploadNewVersion(string appId)
    {
        Navigation.NavigateTo($"/upload");
    }

    private static string Capitalize(string tag)
        => string.IsNullOrEmpty(tag) ? tag : char.ToUpperInvariant(tag[0]) + tag[1..];

    private static string FormatSize(long bytes)
    {
        string[] units = ["B", "KB", "MB", "GB", "TB"];
        double size = bytes;
        int unitIndex = 0;

        while (size >= 1000 && unitIndex < units.Length - 1)
        {
            size /= 1000;
            unitIndex++;
        }

        return unitIndex == 0
            ? $"{size:0} {units[unitIndex]}"
            : $"{size:0.#} {units[unitIndex]}";
    }

    private static string FormatRelativeDate(DateTime uploadedAt)
    {
        var today = DateTime.Now.Date;
        var date = uploadedAt.Date;

        if (date == today)
            return "Today";

        if (date == today.AddDays(-1))
            return "Yesterday";

        if (date > today.AddDays(-7))
            return uploadedAt.ToString("dddd");

        return uploadedAt.ToString(uploadedAt.Year == today.Year ? "MMM d" : "MMM d, yyyy");
    }
}
