@page "/upload"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Authorization
@using WinterRose.Nexus.Registry.Features.FileUploads.Services
@using WinterRose.Nexus.Registry.Features.FileUploads.Models
@using WinterRose.Nexus.Registry.Features.Components
@using WinterRose.Nexus.Shared

@attribute [Authorize]

@inject UploadService UploadService
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageContainer>
    <PageHeader Title="Publish Application" Subtitle="Upload a new build or version" />

    @if (files is null)
    {
        <!-- Drop / Select Area -->
        <Card>
            <div id="dropZone"
                 class="upload-drop-zone"
                 @onclick="TriggerFilePicker">
                <div class="upload-drop-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                        <polyline points="17 8 12 3 7 8" />
                        <line x1="12" y1="3" x2="12" y2="15" />
                    </svg>
                </div>
                <p class="upload-drop-text">Drop your build folder or click to select</p>
                <small class="text-muted">Nexus will infer metadata automatically</small>
            </div>
        </Card>
    }

    <InputFile id="folderInput"
               OnChange="HandleFiles"
               multiple
               webkitdirectory
               style="display:none;" />

    @if (files is not null)
    {
        <div class="nx-spacing-md">
            <div class="upload-status">
                <strong>@files.Count files detected</strong>
                <Button Variant="ButtonVariant.Link" OnClick="ResetSelection">change selection</Button>
            </div>
        </div>

        <!-- Metadata Preview -->
        <Card>
            <div class="form-group">
                <h3 class="form-section-title">Detected Application Info</h3>

                <TextInput Label="Internal Name" @bind-Value="name" />
                <small class="nx-input-helper">Suggested: @suggestedName</small>

                <div class="form-group">
                    <label class="nx-input-label">Version</label>
                    <div class="version-editor">
                        <NumericInput Class="version-number"
                                      @bind-Value="versionMajor"
                                      @bind-Value:after="UpdateVersion"
                                      Min="0" />

                        <span class="version-separator">.</span>

                        <NumericInput Class="version-number"
                                      @bind-Value="versionMinor"
                                      @bind-Value:after="UpdateVersion"
                                      Min="0" />

                        <span class="version-separator">.</span>

                        <NumericInput Class="version-number"
                                      @bind-Value="versionPatch"
                                      @bind-Value:after="UpdateVersion"
                                      Min="0" />

                        <span class="version-separator">-</span>

                        <TextInput Class="version-suffix"
                                   @bind-Value="versionSuffix"
                                   @bind-Value:after="UpdateVersion"
                                   Placeholder="optional, e.g. beta" />
                    </div>
                    <small class="nx-input-helper">Suggested: @suggestedVersion &middot; Resulting version: @version</small>
                </div>

                <TextInput Label="Publisher" @bind-Value="publisher" />
                <TextInput Label="Short Description" @bind-Value="shortDescription" />
                <TextArea Label="Long Description" @bind-Value="longDescription" Rows="3" />
                <TextInput Label="Tags (comma separated)" @bind-Value="tagsInput" />
            </div>
        </Card>

        <!-- Launch target preview -->
        @if (launchTargetOptions.Count > 0)
        {
            <Card>
                <div class="form-group">
                    <Select Label="Launch Target" @bind-Value="launchTarget" 
                           Options="launchTargetOptions.Select(o => new Select.SelectOption { Value = o, Label = o }).ToList()" />
                </div>
            </Card>
        }

        <div class="button-group">
            <Button Variant="ButtonVariant.Primary" 
                   Disabled="@(!CanUpload)" 
                   OnClick="CommitUpload">
                Publish to Nexus
            </Button>
        </div>

        @if (result is not null)
        {
            <div class="alert alert-success">
                Uploaded to: @result.TargetPath
            </div>
        }
    }
</PageContainer>

@code
{
    private string name = "";
    private string suggestedName = "";

    private int versionMajor = 1;
    private int versionMinor = 0;
    private int versionPatch = 0;
    private string versionSuffix = "";

    private string version = "1.0.0";
    private string suggestedVersion = "";

    private string publisher = "";
    private string shortDescription = "";
    private string longDescription = "";
    private string tagsInput = "";

    private IJSObjectReference? module;

    private IReadOnlyList<IBrowserFile>? files;
    private string[]? relativePaths;

    private UploadResult? result;

    private string launchTarget = "";
    private List<string> launchTargetOptions = new();

    private static readonly HashSet<string> NonExecutableExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".txt", ".md", ".json", ".xml", ".yml", ".yaml", ".png", ".jpg", ".jpeg",
        ".gif", ".bmp", ".ico", ".svg", ".dll", ".pdb", ".config", ".lock",
        ".gitignore", ".gitattributes", ".license", ".log", ".zip", ".tar",
        ".gz", ".7z", ".rar", ".pak", ".dat", ".bin", ".dat", ".html", ".css",
        ".js", ".ts", ".csproj", ".sln", ".editorconfig", ".pdf"
    };

    private bool CanUpload =>
        files is not null &&
        !string.IsNullOrWhiteSpace(name) &&
        !string.IsNullOrWhiteSpace(version);

    private async Task TriggerFilePicker()
    {
        if (module is null)
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./js/fileUpload.js");

        await module.InvokeVoidAsync("triggerClick", "folderInput");
    }

    private async Task HandleFiles(InputFileChangeEventArgs e)
    {
        files = e.GetMultipleFiles(int.MaxValue);

        module ??= await JS.InvokeAsync<IJSObjectReference>("import", "./js/fileUpload.js");
        relativePaths = await module.InvokeAsync<string[]>("getRelativePaths", "folderInput");

        relativePaths = relativePaths.Select(RemoveFirstPathSegment).ToArray();
        
        suggestedName = SuggestNameFromFiles(relativePaths.ToList());
        name = suggestedName;

        suggestedVersion = GuessVersionFromFiles(files);
        ApplySuggestedVersion(suggestedVersion);

        launchTargetOptions = DetectLaunchTargets(relativePaths.ToList());
        launchTarget = launchTargetOptions.FirstOrDefault() ?? "";
    }
    
    private static string RemoveFirstPathSegment(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return path;

        path = path.Replace("\\", "/");

        int firstSlashIndex = path.IndexOf('/');

        if (firstSlashIndex >= 0 && firstSlashIndex < path.Length - 1)
            return path[(firstSlashIndex + 1)..];

        return path; // no folder, already root
    }

    private void ResetSelection()
    {
        files = null;
        relativePaths = null;
        name = "";
        suggestedName = "";
        launchTarget = "";
        launchTargetOptions = new();
        versionMajor = 1;
        versionMinor = 0;
        versionPatch = 0;
        versionSuffix = "";
        version = "1.0.0";
        suggestedVersion = "";
    }

    private void ApplySuggestedVersion(string suggested)
    {
        // suggested is expected as "x.y.z" or "x.y.z-suffix"
        var dashIndex = suggested.IndexOf('-');
        var core = dashIndex >= 0 ? suggested[..dashIndex] : suggested;
        var suffix = dashIndex >= 0 ? suggested[(dashIndex + 1)..] : "";

        var parts = core.Split('.');

        versionMajor = parts.Length > 0 && int.TryParse(parts[0], out var maj) ? maj : 1;
        versionMinor = parts.Length > 1 && int.TryParse(parts[1], out var min) ? min : 0;
        versionPatch = parts.Length > 2 && int.TryParse(parts[2], out var pat) ? pat : 0;
        versionSuffix = suffix;

        UpdateVersion();
    }

    private void UpdateVersion()
    {
        version = $"{versionMajor}.{versionMinor}.{versionPatch}";

        if (!string.IsNullOrWhiteSpace(versionSuffix))
            version += $"-{versionSuffix.Trim()}";
    }

    private string SuggestNameFromFiles(IReadOnlyList<string> files)
    {
        var exe = files.FirstOrDefault(f =>
            f.EndsWith(".exe", StringComparison.OrdinalIgnoreCase));

        if (exe is not null)
            return CleanNameFromFile(exe);

        var rootFiles = files
            .Where(f => !f.Contains('/') && !f.Contains('\\'))
            .ToList();

        if (rootFiles.Count > 0)
            return CleanNameFromFile(rootFiles[0]);

        return CleanNameFromFile(files[0]);
    }

    private string CleanNameFromFile(string fileName)
    {
        var name = Path.GetFileNameWithoutExtension(fileName);

        name = System.Text.RegularExpressions.Regex.Replace(
            name,
            @"(\d+(\.\d+)+|\bv\d+\b)",
            "",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase);

        return name.Replace("_", " ")
            .Replace("-", " ")
            .Trim();
    }

    private string GuessVersionFromFiles(IReadOnlyList<IBrowserFile> files)
    {
        var exe = files.FirstOrDefault(f =>
            f.Name.EndsWith(".exe", StringComparison.OrdinalIgnoreCase));

        if (exe is null)
            return "1.0.0";

        var name = Path.GetFileNameWithoutExtension(exe.Name);

        var match = System.Text.RegularExpressions.Regex.Match(name, @"\d+(\.\d+)+");

        return match.Success ? match.Value : "1.0.0";
    }

    private async Task CommitUpload()
    {
        if (files is null || relativePaths is null)
            return;

        var uploads = files.Zip(relativePaths, (file, path) => (file, path));

        var tags = tagsInput
            .Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .ToList();

        var appEntry = new AppEntry
        {
            AppId = name,
            DisplayName = string.IsNullOrWhiteSpace(name) ? suggestedName : name,
            Publisher = publisher,
            ShortDescription = shortDescription,
            LongDescription = longDescription,
            Tags = tags
        };

        var versionObj = new AppVersion(version)
        {
            LaunchTarget = new AppLaunchTarget
            {
                Path = launchTarget,
                Arguments = []
            },
            Changelog = ""
        };

        await UploadService.SaveAsync(appEntry, versionObj, uploads);

        Navigation.NavigateTo("/uploads/list");
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        module = await JS.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/fileUpload.js");

        await module.InvokeVoidAsync(
            "setupDropZone",
            "dropZone",
            "folderInput");
    }

    private List<string> DetectLaunchTargets(IReadOnlyList<string> files)
    {
        var exeFiles = files
            .Where(f => f.EndsWith(".exe", StringComparison.OrdinalIgnoreCase))
            .ToList();

        var shFiles = files
            .Where(f => f.EndsWith(".sh", StringComparison.OrdinalIgnoreCase))
            .ToList();

        var linuxBinaries = files
            .Where(f => !exeFiles.Contains(f) && !shFiles.Contains(f))
            .Where(IsLikelyLinuxBinary)
            .ToList();

        return exeFiles
            .Concat(linuxBinaries)
            .Concat(shFiles)
            .ToList();
    }

    private bool IsLikelyLinuxBinary(string filePath)
    {
        var fileName = Path.GetFileName(filePath);

        // Skip dotfiles/hidden files (.gitignore, .env, etc.)
        if (fileName.StartsWith('.'))
            return false;

        var ext = Path.GetExtension(fileName);

        // Has a recognized non-executable extension -> not a binary
        if (!string.IsNullOrEmpty(ext) && NonExecutableExtensions.Contains(ext))
            return false;

        // Has *any* extension at all -> probably not a Linux binary
        // (Linux executables conventionally have no extension)
        if (!string.IsNullOrEmpty(ext))
            return false;

        return true;
    }
}
