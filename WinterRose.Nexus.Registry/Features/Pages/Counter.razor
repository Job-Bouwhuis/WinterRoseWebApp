@page "/counter"
@rendermode InteractiveServer

@using WinterRose.Nexus.Registry.Features.Components

<PageContainer>
    <PageHeader Title="Counter" Subtitle="A simple interactive counter example" />

    <Card>
        <div class="counter-demo">
            <p class="counter-status">Current count: <strong>@currentCount</strong></p>
            <Button Variant="ButtonVariant.Primary" OnClick="IncrementCount">Click me</Button>
        </div>
    </Card>
</PageContainer>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;
    }
}
