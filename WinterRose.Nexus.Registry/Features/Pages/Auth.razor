@page "/auth"

@using Microsoft.AspNetCore.Authorization
@using WinterRose.Nexus.Registry.Features.Components

@attribute [Authorize]

<PageContainer>
    <PageHeader Title="You are authenticated" Subtitle="Welcome back!" />

    <Card>
        <AuthorizeView>
            <p class="auth-greeting">Hello <strong>@context.User.Identity?.Name</strong>!</p>
            <p class="text-muted">You have successfully logged in to the system.</p>
        </AuthorizeView>
    </Card>
</PageContainer>
