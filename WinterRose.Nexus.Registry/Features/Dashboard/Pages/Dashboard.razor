@page "/dashboard"

@rendermode InteractiveServer

@using Features.Dashboard.Models
@using Features.Dashboard.Services
@using WinterRose.Nexus.Registry.Features.Dashboard.Components
@using WinterRose.Nexus.Registry.Features.Components

@inject DashboardDataService DashboardDataService
@inject ILogger<Dashboard> logger

<PageContainer>
    <PageHeader Title="System Dashboard" Subtitle="View system status and metrics">
        <Button Variant="ButtonVariant.Secondary" OnClick="Reload">Refresh Data</Button>
    </PageHeader>

    @if (cards is null)
    {
        <Card>
            <p class="text-muted">Loading...</p>
        </Card>
    }
    else
    {
        <div class="dashboard-grid">
            @foreach (var card in cards)
            {
                <DashboardCard Model="card" />
            }
        </div>
    }
</PageContainer>

@code {
    private List<DashboardCardModel>? cards;

    protected override async Task OnInitializedAsync()
    {
        await Load();
    }

    private async Task Load()
    {
        cards = await DashboardDataService.GetCardsAsync();
    }

    private async Task Reload()
    {
        await Load();
    }
}