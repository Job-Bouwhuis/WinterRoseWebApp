@if (AsLink)
{
    <a href="@Href" class="nx-btn @ButtonClass @GetVariantClass() @AdditionalClass" @onclick="OnClick">
        @ChildContent
    </a>
}
else if (Submit)
{
    <button type="submit" class="nx-btn @ButtonClass @GetVariantClass() @AdditionalClass" @onclick="OnClick" disabled="@Disabled">
        @ChildContent
    </button>
}
else
{
    <button type="button" class="nx-btn @ButtonClass @GetVariantClass() @AdditionalClass" @onclick="OnClick" disabled="@Disabled">
        @ChildContent
    </button>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? ButtonClass { get; set; }

    [Parameter] public string AdditionalClass { get; set; } = "";

    [Parameter]
    public ButtonVariant Variant { get; set; } = ButtonVariant.Primary;

    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Submit { get; set; }

    [Parameter]
    public bool AsLink { get; set; }

    [Parameter]
    public string? Href { get; set; }

    private string GetVariantClass() => Variant switch
    {
        ButtonVariant.Primary => "btn-primary",
        ButtonVariant.Secondary => "btn-secondary",
        ButtonVariant.Outline => "btn-outline",
        ButtonVariant.Link => "btn-link",
        ButtonVariant.Ghost => "btn-ghost",
        ButtonVariant.Danger => "btn-danger",
        _ => "nx-btn--primary"
    };
}
