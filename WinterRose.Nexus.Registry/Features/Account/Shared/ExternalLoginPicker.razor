@using Microsoft.AspNetCore.Authentication
@using Microsoft.AspNetCore.Identity
@using WinterRose.Nexus.Registry.Data
@using WinterRose.Nexus.Registry.Features.Components

@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager

@if (externalLogins.Length == 0)
{
    <div class="external-login-empty">
        <p>No external authentication providers are configured.</p>
        <a href="https://go.microsoft.com/fwlink/?LinkID=532715" target="_blank">
            Setup guide for external login providers
        </a>
    </div>
}
else
{
    <form action="Account/PerformExternalLogin" method="post" class="external-login-form">
        <AntiforgeryToken />
        <input type="hidden" name="ReturnUrl" value="@ReturnUrl" />

        <div class="external-login-grid">
            @foreach (var provider in externalLogins)
            {
                <button type="submit"
                        class="external-login-btn"
                        name="provider"
                        value="@provider.Name">
                    @provider.DisplayName
                </button>
            }
        </div>
    </form>
}

@code {
    private AuthenticationScheme[] externalLogins = [];

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        externalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).ToArray();
    }
}
