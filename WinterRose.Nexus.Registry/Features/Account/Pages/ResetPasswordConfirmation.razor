@page "/Account/ResetPasswordConfirmation"

<PageTitle>Password reset complete</PageTitle>

<div class="nexus-auth-card">

    <div class="nexus-access-icon">
        <div class="nexus-lock-pulse">
            <svg width="42" height="42" viewBox="0 0 24 24" fill="none">
                <path d="M12 2l7 4v6c0 5-3 9-7 10-4-1-7-5-7-10V6l7-4z"
                      stroke="currentColor"
                      stroke-width="1.5"/>

                <path d="M9 12l2 2 4-5"
                      stroke="currentColor"
                      stroke-width="1.5"
                      stroke-linecap="round"/>
            </svg>
        </div>
    </div>

    <h1 class="nexus-auth-title">Password updated</h1>

    <p class="nexus-text-muted">
        Your password has been successfully reset. You can now sign in with your new credentials.
    </p>

    <div class="nexus-access-actions">
        <a class="nexus-btn nexus-btn-primary w-100" href="Account/Login">
            Continue to login
        </a>
    </div>
</div>