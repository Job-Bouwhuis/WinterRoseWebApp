@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using WinterRose.Nexus.Registry.Features.Components

@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Forgot your password?</PageTitle>

<PageContainer>
    <PageHeader Title="Forgot your password?" Subtitle="Enter your email to receive password reset instructions" />

    <Card>
        <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />

            <div class="form-group">
                <TextInput 
                    Label="Email"
                    @bind-Value="Input.Email"
                    InputType="email"
                    Placeholder="name@example.com"
                    Required="true"
                    ShowValidation="true"
                    ErrorMessage="@GetValidationError(() => Input.Email)" />
            </div>

            <Button Variant="ButtonVariant.Primary" Submit="true">
                Send password reset link
            </Button>
        </EditForm>
    </Card>
</PageContainer>

@code {
    private EditContext editContext = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    protected override void OnInitialized()
    {
        Input ??= new();
        editContext = new EditContext(Input);
    }

    public async Task OnValidSubmitAsync()
    {
        RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
    }

    private string? GetValidationError<TValue>(System.Linq.Expressions.Expression<Func<TValue>> accessor)
    {
        try
        {
            if (editContext != null && editContext.IsModified())
            {
                var fieldName = GetFieldName(accessor);
                var field = editContext.Field(fieldName);
                return editContext.GetValidationMessages(field).FirstOrDefault();
            }
        }
        catch { }
        return null;
    }

    private string GetFieldName<TValue>(System.Linq.Expressions.Expression<Func<TValue>> accessor)
    {
        var expression = (System.Linq.Expressions.MemberExpression)accessor.Body;
        return expression.Member.Name;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }
}
