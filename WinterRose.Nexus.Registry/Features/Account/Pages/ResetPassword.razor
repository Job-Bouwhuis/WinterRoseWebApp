@page "/Account/ResetPassword"

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Identity
@using WinterRose.Nexus.Registry.Data
@using WinterRose.Nexus.Registry.Features.Components

@inject UserManager<ApplicationUser> UserManager
@inject IdentityRedirectManager RedirectManager

<PageTitle>Reset password</PageTitle>

<PageContainer>
    <PageHeader Title="Reset your password" Subtitle="Enter a new password for your account" />

    <Card>
        <EditForm Model="Input" FormName="reset-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />

            <div class="form-group">
                <TextInput 
                    Label="Email"
                    @bind-Value="Input.Email"
                    InputType="email"
                    Required="true"
                    Disabled="true" />

                <TextInput 
                    Label="Password"
                    @bind-Value="Input.Password"
                    InputType="password"
                    Required="true"
                    ShowValidation="true"
                    ErrorMessage="@GetValidationError(() => Input.Password)" />

                <TextInput 
                    Label="Confirm password"
                    @bind-Value="Input.ConfirmPassword"
                    InputType="password"
                    Required="true"
                    ShowValidation="true"
                    ErrorMessage="@GetValidationError(() => Input.ConfirmPassword)" />
            </div>

            <Button Variant="ButtonVariant.Primary" Submit="true">
                Reset password
            </Button>
        </EditForm>
    </Card>
</PageContainer>

@code {
    private EditContext editContext = default!;

    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = default!;

    [SupplyParameterFromQuery]
    private string? Code { get; set; }

    protected override void OnInitialized()
    {
        if (Code is null)
        {
            RedirectManager.RedirectTo("Account/InvalidUserCode");
        }

        Input ??= new();
        editContext = new EditContext(Input);
    }

    private async Task OnValidSubmitAsync()
    {
        var user = await UserManager.FindByEmailAsync(Input.Email);
        if (user is null)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
            return;
        }

        var result = await UserManager.ResetPasswordAsync(user, Code, Input.Password);
        if (result.Succeeded)
        {
            RedirectManager.RedirectTo("Account/ResetPasswordConfirmation");
        }
    }

    private string? GetValidationError<TValue>(System.Linq.Expressions.Expression<Func<TValue>> accessor)
    {
        try
        {
            if (editContext != null && editContext.IsModified())
            {
                var fieldName = GetFieldName(accessor);
                var field = editContext.Field(fieldName);
                return editContext.GetValidationMessages(field).FirstOrDefault();
            }
        }
        catch { }
        return null;
    }

    private string GetFieldName<TValue>(System.Linq.Expressions.Expression<Func<TValue>> accessor)
    {
        var expression = (System.Linq.Expressions.MemberExpression)accessor.Body;
        return expression.Member.Name;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        [DataType(DataType.Password)]
        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string ConfirmPassword { get; set; } = "";

        [Required]
        public string Code { get; set; } = "";
    }
}
