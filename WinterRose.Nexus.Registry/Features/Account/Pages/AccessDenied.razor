@page "/Account/AccessDenied"
@using WinterRose.Nexus.Registry.Features.Components

<PageTitle>Access denied</PageTitle>

<PageContainer>
    <Card>
        <div class="access-denied-container">
            <div class="access-denied-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                    <path d="M7 10V8a5 5 0 0110 0v2" stroke-linecap="round"/>
                    <path d="M6 10h12v10H6V10z" stroke-linejoin="round"/>
                    <path d="M12 14v2" stroke-linecap="round"/>
                </svg>
            </div>

            <h1 class="access-denied-title">Access Denied</h1>

            <p class="access-denied-message">
                You don't have permission to access this page. If you think this is a mistake, please contact support or try logging in with a different account.
            </p>

            <div class="access-denied-actions">
                <a href="/" class="nx-link-button">Return to home</a>
                <a href="/Account/Login" class="nx-link-button">Log in with another account</a>
            </div>
        </div>
    </Card>
</PageContainer>
