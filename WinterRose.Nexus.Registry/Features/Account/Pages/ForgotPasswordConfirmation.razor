@page "/Account/ForgotPasswordConfirmation"

<PageTitle>Forgot password</PageTitle>

<div class="nexus-auth-card nexus-confirm">
    <div class="nexus-confirm-icon nexus-confirm-success">✓</div>

    <h1 class="nexus-auth-title">Check your email</h1>

    <p class="nexus-text-muted">
        If an account exists for that email, you’ll receive a password reset link shortly.
    </p>

    <p class="nexus-text-muted">
        Didn’t get anything? Check your spam folder or try again in a few minutes.
    </p>
</div>