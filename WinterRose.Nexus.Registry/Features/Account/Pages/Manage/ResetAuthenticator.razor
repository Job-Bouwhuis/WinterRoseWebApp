@page "/Account/Manage/ResetAuthenticator"

@using Microsoft.AspNetCore.Identity
@using WinterRose.Nexus.Registry.Data

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ResetAuthenticator> Logger

<PageTitle>Reset authenticator</PageTitle>

<div class="nexus-page-section nexus-page-section--center">

    <div class="nexus-card nexus-card--danger">

        <div class="nexus-text-title-sm">
            Reset authenticator key
        </div>

        <StatusMessage />

        <div class="nexus-warning-box">

            <div class="nexus-warning-title">
                Warning
            </div>

            <div class="nexus-text-muted">
                Resetting your authenticator key will immediately invalidate your current authenticator app setup.
            </div>

            <div class="nexus-text-muted">
                Two-factor authentication will be disabled until you complete setup again.
            </div>

        </div>

        <form @formname="reset-authenticator"
              @onsubmit="OnSubmitAsync"
              method="post">

            <AntiforgeryToken />

            <button type="submit"
                    class="nexus-btn nexus-btn--danger">
                Reset authenticator key
            </button>

        </form>

    </div>

</div>

@code {
    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    private async Task OnSubmitAsync()
    {
        var user = await UserManager.GetUserAsync(HttpContext.User);
        if (user is null)
        {
            RedirectManager.RedirectToInvalidUser(UserManager, HttpContext);
            return;
        }

        await UserManager.SetTwoFactorEnabledAsync(user, false);
        await UserManager.ResetAuthenticatorKeyAsync(user);
        var userId = await UserManager.GetUserIdAsync(user);
        Logger.LogInformation("User with ID '{UserId}' has reset their authentication app key.", userId);

        await SignInManager.RefreshSignInAsync(user);

        RedirectManager.RedirectToWithStatus(
            "Account/Manage/EnableAuthenticator",
            "Your authenticator app key has been reset, you will need to configure your authenticator app using the new key.",
            HttpContext);
    }
}
